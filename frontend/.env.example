# Copy to .env for local dev. In Vercel, set this under
# Project Settings -> Environment Variables instead.

# Local Flask dev server:
VITE_API_URL=http://localhost:5000

# Production (after the backend is deployed on Render):
# VITE_API_URL=https://green-idea-backend.onrender.com

# Used client-side to upload equipment images to Supabase Storage.
# Supabase Dashboard -> your project -> Project Settings -> API.
# This is the public anon/publishable key, not the secret service_role key.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
