# Copy this file to .env and fill in real values. .env is gitignored and
# must never be committed. In Render, set these same keys under your
# service's Environment tab instead of uploading a file.

# --- Database (Supabase Postgres) ---
# Supabase Dashboard -> your project -> Project Settings -> Database ->
# Connection string -> URI. Use the direct connection (port 5432), not
# the pooler, since this app is a persistent server, not serverless.
DATABASE_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# --- Auth ---
# JWT_SECRET: any long random string, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET=
# The one login that bypasses the users table - keep this password strong.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Mail (Gmail SMTP + App Password, used to send OTP emails) ---
# Use a Google Account App Password, not the account's normal login password:
# Google Account -> Security -> 2-Step Verification -> App passwords.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-app-gmail@gmail.com
MAIL_PASSWORD=your16charapppassword

# --- Third-party APIs ---
GROQ_API_KEY=
OPENWEATHER_API_KEY=

# --- CORS: comma-separated list of frontend origins allowed to call this API ---
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:19006

# --- Server ---
FLASK_DEBUG=false
PORT=5000
